declare -a pkgsBuildHost=('/nix/store/dylb15qgy2c5lmgn3qg9v89lswdhkgk7-nextpnr-xilinx-0.8.2-unstable-2026-02-09' '/nix/store/j9cnbvj4an4zrjd1snmf5z1mixv39d02-nextpnr-xilinx-chipdb-artix7-0.8.2-unstable-2026-02-09' '/nix/store/48q4n8vmpkgzxxvkh6k9dwb7dg13pm08-prjxray-unstable-2024-01-15' '/nix/store/ys74caqrfx479869am6hdljqcc7f4psg-yosys-0.62' '/nix/store/kp4j3zz6n72s20v636c3w85agj7c24s6-libffi-3.5.2-dev' '/nix/store/s644cyhhkg9zjgk924ap5wwr96jn71d3-libffi-3.5.2' '/nix/store/nldbqqf8gsg8h0vqjmb9pg75nxf3iwqn-readline-8.3p3-dev' '/nix/store/n7iyqawbhv90ikx7casy5sapwpqj870b-ncurses-6.6-dev' '/nix/store/z2903hglhpxv4hyczli0ncdf09wmma92-ncurses-6.6' '/nix/store/8pqj80100baxyhcl9g03b7ywpj4s5mah-readline-8.3p3' '/nix/store/bm9kfmhbvxyr7axhn8qsianz38ck9gkf-tcl-8.6.16' '/nix/store/wlafyp4d5mjdfvkj88m4l2a84fzcxjfv-zlib-1.3.1-dev' '/nix/store/ri9paa3mri4kqakljak8ldvbcp7lpmif-zlib-1.3.1' '/nix/store/857yj0gqncv8hzbkyzc9g4q0xgdqn7km-python3-3.13.11-env' '/nix/store/7kv3bf1pbzk39c7a1n7h8rlr1snqk55x-boost-1.87.0-dev' '/nix/store/ixclwd1qpp1zvccjswrnl911y7rp5r33-boost-1.87.0' '/nix/store/vb2mk2583d5hn9yc0fw5zx3a7mblvncn-python3.13-litex-e4179f98beb52d115bdd4b3d359e4fe0cd5120fc' '/nix/store/hxnfm94wcpbvnzf00xfzqv7ba6l9rp2l-python3.13-pythondata-software-compiler_rt-fcb03245613ccf3079cc833a701f13d0beaae09d' '/nix/store/slhpx9glq7vl99bwi93bgrhn3syv98s1-python3-3.13.11' '/nix/store/8fyd1n9b73iwjxmybhk1ag22lh4qz9cp-python3.13-pythondata-software-picolibc-a5e11229885a87083ec54034f8d693ba52ea2718' '/nix/store/8yni4m375ypf01720hm9l9km775822gb-meson-1.9.1' '/nix/store/7j3d43wilr4ihaf0ivv1mwyxbn6jfv18-python3.13-ninja-1.13.2' '/nix/store/7kad3pafp11khw3capr8nnxmpl0dvp0h-python3.13-pyserial-3.5' '/nix/store/0k36lc19w7s6y448p247fvklz8lglp8p-python3.13-migen-0.9.2-unstable-2025-10-03' '/nix/store/f5avbm4c7x19h9shspkbrf5kwi3gz0wp-python3.13-colorama-0.4.6' '/nix/store/7y4kwfy5la7zpv8m36r1klcgv4rm0h0v-python3.13-requests-2.32.5' '/nix/store/xxdp6hzw4w2chgx3xmshai71387qb5p6-python3.13-certifi-2025.