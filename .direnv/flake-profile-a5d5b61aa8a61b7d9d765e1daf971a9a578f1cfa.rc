x/store/5fylpn8a9hgfw20i9884qqd7z6dbj703-python3.13-litedram-51de2b05e9b8e555cde8ff5508b5996945a2fd22' '/nix/store/pq2yqvxxm3fc6cd7ifjl5ak90mj904lq-python3.13-liteeth-5689d38172f2abcfc177b2714b7eb46c13231776' '/nix/store/79b2127f0nhxz6ypy8cijyp0jir76ma9-python3.13-liteiclink-678793d77542862dc2256e599802835bb7c85d6d' '/nix/store/06k5fw310fqrcpngd1by226v5yvy9g7s-python3.13-litescope-92835f00d2f97d5b9415c39e52b1bc9b6d1d8641' '/nix/store/4wzlglk320gpq6bcck31i7g53w5wr7qb-python3.13-litespi-4c04564178fb3314ed2e33c56afb8e313eda45e3' '/nix/store/x2wj25arwi71yai9s8qpqpzmm2675fcl-python3.13-litepcie-a8a8e7ee10dc2cc5b888c4e069391bd7370710ba' '/nix/store/lfn245ijyxayf5bill8riizsmpvl6dig-python3.13-litehyperbus-76454e4c0c304a34b9915722de750887c3abbe89' '/nix/store/5zcr36bjz3dvk95z9s12vp72bl5l94r2-python3.13-litesdcard-80a3004a28028aaecfc9f9733aa6bc8ea755a5cf' '/nix/store/p54zhyk8z6cnhmjgdlzy8ysykrj576na-python3.13-litevideo-41f30143075ece3fff5c33a332ed067d1837cbb3' '/nix/store/l5k7qg77y9yg2hx8frlmpn27c09iyf20-python3.13-litesata-c4baa461915bf2e88436fd817472de2f173b2c69' '/nix/store/jv72zw1s2qaj890vm4h7irwny97206dd-python3.13-litejesd204b-c2622afec5f427db386d702818f2699fd0568231' '/nix/store/nb6i9l0wqmwm90bv0zip88j2bmssb9i7-python3.13-litei2c-66214caefb382a87ba15de63c555780d448ec108' '/nix/store/mbkzi8bpqc2sra7grndqvcx0np4ppz4x-verilator-5.044' '/nix/store/vir42hllfdn2ycvfxnw89wv3zhr6npv2-libevent-2.1.12-dev' '/nix/store/1b05z3z1siix4zagbbjkx4dph5sfm9il-libevent-2.1.12' '/nix/store/scn8z5clkrlb1byslr00b05nv3inpgls-libevent-2.1.12-openssl' '/nix/store/yzyiva6j0b0xxq5pwiiamp2hdai632mn-json-c-0.18-dev' '/nix/store/kn9jqbdnq8ngp0375r7nvlvn40gxlqfd-json-c-0.18' '/nix/store/8w1fykd8l3xp1lfiwyrakjlv8lfcrh6i-zeromq-4.3.5' '/nix/store/bcr9hca88krfcm7d4p4cww7d971y04gm-riscv64-unknown-linux-gnu-gcc-wrapper-15.2.0' '/nix/store/hf1z5s4pqbmza4rz1xln6330g9q0ydqc-riscv64-unknown-linux-gnu-binutils-wrapper-2.44' '/nix/store/c2p7haf4zzkbrir9zs662r68c5dmylbq-patchelf-0.15.2' '/nix/store/y03z7y8cgdc